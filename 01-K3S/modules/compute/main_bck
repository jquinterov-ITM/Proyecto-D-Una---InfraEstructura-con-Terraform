
locals {
  app_subnets_effective = var.app_subnets
  total_masters         = var.master_count
  master_private_ips    = [for i in range(var.master_count) : cidrhost(var.app_subnet_cidrs[i % length(var.app_subnet_cidrs)], 10 + i)]
  instance_profile_name = null # O el valor correcto si se usa IAM
  worker_suffixes       = ["Client", "Proveedor", "Admin", "Client", "Proveedor", "Admin"]
}

resource "aws_instance" "master_primary" {
  ami                         = "ami-0c7217cdde317cfec"
  instance_type               = var.master_type
  subnet_id                   = local.app_subnets_effective[0]
  private_ip                  = local.master_private_ips[0]
  vpc_security_group_ids      = [var.sg_master_id]
  iam_instance_profile        = local.instance_profile_name
  associate_public_ip_address = true
  key_name                    = var.key_name
  user_data                   = <<-EOF
              #!/bin/bash
              curl -sfL https://get.k3s.io | 
              K3S_TOKEN=${var.k3s_token} sh -s server --cluster-init --write-kubeconfig-mode 644
              EOF
  tags                        = { Name = "Master-${var.env}-0" }
}

resource "aws_instance" "master_secondary" {
  count                       = max(local.total_masters - 1, 0)
  ami                         = "ami-0c7217cdde317cfec"
  instance_type               = var.master_type
  subnet_id                   = local.app_subnets_effective[count.index + 1]
  private_ip                  = local.master_private_ips[count.index + 1]
  vpc_security_group_ids      = [var.sg_master_id]
  iam_instance_profile        = local.instance_profile_name
  associate_public_ip_address = true
  key_name                    = var.key_name
  user_data                   = <<-EOF
              #!/bin/bash
              sleep 60
              curl -sfL https://get.k3s.io | 
              K3S_URL=https://${aws_instance.master_primary.private_ip}:6443 \
              K3S_TOKEN=${var.k3s_token} sh -s server
              EOF
  tags                        = { Name = "Master-${var.env}-${count.index + 1}" }
}


resource "aws_instance" "worker" {
  count                  = var.worker_count
  ami                    = "ami-0c7217cdde317cfec"
  instance_type          = var.worker_type
  subnet_id              = local.app_subnets_effective[count.index % length(local.app_subnets_effective)]
  vpc_security_group_ids = [var.sg_worker_id]
  iam_instance_profile   = local.instance_profile_name
  key_name               = var.key_name
  user_data              = <<-EOF
              #!/bin/bash
              sleep 60
              # Set hostname based on mapping: worker-<n>-<suffix>
              hostnamectl set-hostname worker-$(( ${count.index} + 1 ))-${length(local.worker_suffixes) > count.index ? local.worker_suffixes[count.index] : "worker"}
              curl -sfL https://get.k3s.io | 
              K3S_URL=https://${aws_instance.master_primary.private_ip}:6443 \
              K3S_TOKEN=${var.k3s_token} sh -s - agent --kubelet-arg=max-pods=${var.worker_max_pods}
              EOF
  tags = {
    Name = "worker-${count.index + 1}-${length(local.worker_suffixes) > count.index ? local.worker_suffixes[count.index] : "worker"}"
  }
}

output "worker_ids" { value = aws_instance.worker[*].id }

output "master_primary_id" {
  description = "Instance ID del master primario"
  value       = aws_instance.master_primary.id
}

output "master_ip" {
  description = "IP pública del master primario"
  value       = aws_instance.master_primary.public_ip
}
